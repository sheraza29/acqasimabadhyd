{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 12
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "warn"
  },
  "globals": {
    "firebase": "readonly",
    "L": "readonly",
    "Chart": "readonly",
    "ExcelJS": "readonly",
    "console": "readonly"
  }
}
